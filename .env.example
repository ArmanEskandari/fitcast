# Fitcast environment variables
# ------------------------------------------------------------------
# Copy this file to `.env.local` (git-ignored) and fill in your values.
# `.env.local` is read by the local dev-api server (`pnpm dev:api`) and,
# once deployed, by the serverless functions in `api/`.

# Anthropic API key — enables AI narration (Claude Haiku 4.5) and the
# "Ask Sprout" assistant (Claude Sonnet 5). Optional: without it the app
# falls back to the rule-engine advice and the assistant shows a
# "needs deployment" note. Get one at https://console.anthropic.com/
# (starts with "sk-ant-").
ANTHROPIC_API_KEY=

# Optional: port the local dev-api server listens on (default 5200).
# If you change it, update the proxy target in rsbuild.config.ts.
# DEV_API_PORT=5200
